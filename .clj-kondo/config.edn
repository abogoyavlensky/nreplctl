;; clj-kondo is a Clojure linter; nreplctl is let-go (a Clojure dialect). These
;; entries teach clj-kondo the project's deliberate conventions and let-go's
;; runtime namespaces. None of them silence real bugs.
{:linters
 {;; os is a let-go runtime namespace provided by the interpreter (no require
  ;; exists); clj-kondo can't see it. (net/bencode now live in the
  ;; nrepl-client library, not in nreplctl's own source.)
  :unresolved-namespace {:exclude [os]}}

 :config-in-ns
 {;; let-go's `catch` takes no class: (catch e body). clj-kondo reads it as
  ;; Clojure's (catch Class binding body) and misparses the block, so scope the
  ;; affected linters off in the namespaces that use it.
  nreplctl.core {:linters {:unresolved-symbol {:level :off}
                           :unused-binding {:level :off}
                           :syntax {:level :off}}}}}
