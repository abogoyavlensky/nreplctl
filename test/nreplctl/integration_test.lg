(ns nreplctl.integration-test
  "CLI-level integration: assert eval-cmd's exit codes (0/1/2) against a live
   nREPL server. eval-cmd returns the code as an int (eval-cmd! adds os/exit),
   so this needs no stdout capture. The server-spawn helpers are copied from
   nrepl-client's integration test (they are generic)."
  (:require [clojure.string :as str]
            [clojure.test :refer [deftest is]]
            [nrepl-client.core :as nrepl]
            [nreplctl.core :as cli]))

;; The alias is `cli`, not `core`: a require alias named `core` collides with
;; the auto-referred clojure.core and won't resolve at compile time (let-go bug,
;; reported upstream). Any other alias works, so `cli/eval-cmd` compiles fine.

;; ---- server spawn helpers (generic; see nrepl-client integration test) ----

(defn- lg-binary
  []
  (let [e (os/getenv "LGX_LG")]
    (if (and e (not= "" e)) e "lg")))

(defn- sh-single-quote
  [s]
  (str "'" (str/replace s "'" "'\\''") "'"))

(defn- start-server!
  [port]
  (let [lg (sh-single-quote (lg-binary))
        cmd (str "d=$(mktemp -d) || exit 1; f=\"$d/in\"; mkfifo \"$f\" || exit 1; "
                 "tail -f /dev/null > \"$f\" 2>/dev/null & holder=$!; "
                 lg " -n -p " port " < \"$f\" > /dev/null 2>&1 & server=$!; "
                 "echo \"$server $holder $d\"")
        parts (str/split (str/trim (:out (os/sh "sh" "-c" cmd))) #"\s+")]
    {:pids [(nth parts 0) (nth parts 1)]
     :dir (nth parts 2)}))

(defn- stop-server!
  [{:keys [pids dir]}]
  (os/sh "sh" "-c" (str "kill " (str/join " " pids) " 2>/dev/null; rm -rf " (sh-single-quote dir))))

(defn- wait-connect!
  [host port]
  (loop [i 0]
    (let [conn (try (nrepl/connect! host port) (catch e nil))]
      (cond
        conn conn
        (< i 50) (do (sleep 100) (recur (inc i)))
        :else nil))))

(deftest eval-cmd-exit-codes
  (let [host "127.0.0.1"
        port (os/free-port)
        server (start-server! port)]
    (try
      (let [conn (wait-connect! host port)]
        (is (some? conn) "server should accept a connection")
        (when conn
          ;; close the readiness probe so the test leaves no open socket
          (nrepl/close! conn nil)
          (let [opts {:port (str port)
                      :port-file ".nrepl-port"
                      :host host}]
            ;; 0: a value comes back
            (is (= 0 (cli/eval-cmd {:args {:code "(+ 1 1)"}
                                    :opts opts}))
                "(+ 1 1) succeeds -> exit 0")
            ;; 1: the code throws
            (is (= 1 (cli/eval-cmd {:args {:code "(undefined-fn-xyz)"}
                                    :opts opts}))
                "a thrown form -> exit 1")
            ;; 2: no resolvable port (no --port, absent port file). A per-run
            ;; path nothing creates -> guaranteed absent, no destructive delete.
            (let [absent (str (os/temp-dir) "/nreplctl-cli-test-absent-" (os/free-port))]
              (is (= 2 (cli/eval-cmd {:args {:code "(+ 1 1)"}
                                      :opts {:port nil
                                             :port-file absent
                                             :host host}}))
                  "no port file and no --port -> exit 2")))))
      (finally
        (stop-server! server)))))
