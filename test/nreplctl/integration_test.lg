(ns nreplctl.integration-test
  "End-to-end test against a real lg nREPL server spawned as a subprocess:
   clone once, then several evals over the same session (proving clean stream
   reuse), plus the timeout path. The server is torn down in a finally."
  (:require [clojure.string :as str]
            [clojure.test :refer [deftest is]]
            [nreplctl.nrepl :as nrepl]))

(defn- lg-binary
  "The lg under test: LGX_LG if set (the patched build), else PATH `lg`."
  []
  (let [e (os/getenv "LGX_LG")]
    (if (and e (not= "" e)) e "lg")))

(defn- sh-single-quote
  "POSIX single-quote s for safe embedding in a shell command (handles paths
   with spaces or shell metacharacters)."
  [s]
  (str "'" (str/replace s "'" "'\\''") "'"))

(defn- start-server!
  "Spawn an lg nREPL server on `port`. lg's repl keeps the server alive only
   while its stdin stays open, so we hold it open with `tail` writing into a
   FIFO wired to lg's stdin — portable (no setsid, which macOS lacks). Returns
   a teardown handle {:pids [server-pid holder-pid] :dir fifo-dir}."
  [port]
  (let [lg (sh-single-quote (lg-binary))
        cmd (str "d=$(mktemp -d) || exit 1; f=\"$d/in\"; mkfifo \"$f\" || exit 1; "
                 "tail -f /dev/null > \"$f\" 2>/dev/null & holder=$!; "
                 lg " -n -p " port " < \"$f\" > /dev/null 2>&1 & server=$!; "
                 "echo \"$server $holder $d\"")
        parts (str/split (str/trim (:out (os/sh "sh" "-c" cmd))) #"\s+")]
    {:pids [(nth parts 0) (nth parts 1)]
     :dir (nth parts 2)}))

(defn- stop-server!
  "Kill the server and its stdin holder, then remove the FIFO dir."
  [{:keys [pids dir]}]
  (os/sh "sh" "-c" (str "kill " (str/join " " pids) " 2>/dev/null; rm -rf " (sh-single-quote dir))))

(defn- wait-connect!
  "Retry connect! (~5s) until the server accepts; return a live conn or nil."
  [host port]
  (loop [i 0]
    (let [conn (try (nrepl/connect! host port) (catch e nil))]
      (cond
        conn conn
        (< i 50) (do (sleep 100) (recur (inc i)))
        :else nil))))

(defn- collect-eval
  "Run one eval!, collecting emitted events into a vector; return
   {:events [...] :result {...}}."
  [conn session code opts]
  (let [events (atom [])
        result (nrepl/eval! conn session code
                            (assoc opts :emit (fn [ev] (swap! events conj ev))))]
    {:events @events
     :result result}))

(deftest end-to-end-eval
  (let [host "127.0.0.1"
        port (os/free-port)
        server (start-server! port)]
    (try
      (let [conn (wait-connect! host port)]
        (is (some? conn) "server should accept a connection")
        (when conn
          (let [session (nrepl/clone! conn host port)]
            (is (some? session) "clone returns a session id")

            ;; 1) a value comes back, no error
            (let [{:keys [events result]} (collect-eval conn session "(+ 1 1)" {})]
              (is (contains? (set events) [:value "2"]) "events contain [:value \"2\"]")
              (is (not (:error? result)) "(+ 1 1) is not an error"))

            ;; 2) a thrown form is reported as an error
            (let [{:keys [result]} (collect-eval conn session "(undefined-fn-xyz)" {})]
              (is (:error? result) "(undefined-fn-xyz) is an error"))

            ;; 3) same session still works after the error — clean stream reuse
            (let [{:keys [events result]} (collect-eval conn session "(+ 2 3)" {})]
              (is (contains? (set events) [:value "5"]) "session reuse stays clean")
              (is (not (:error? result)) "(+ 2 3) is not an error"))

            ;; 4) timeout — run last; the late reply may still arrive on the wire
            (let [{:keys [result]} (collect-eval conn session "(do (sleep 5000) 42)"
                                                 {:timeout-ms 100})]
              (is (:timeout? result) "a slow eval under a short timeout times out"))

            (nrepl/close! conn session))))
      (finally
        (stop-server! server)))))
